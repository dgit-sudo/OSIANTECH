<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-content" data-animate="fade-up">
      <div class="section-tag">Checkout</div>
      <h1 class="page-hero-title">Complete Your Enrollment</h1>
      <p class="page-hero-sub">One course at a time. Secure payment powered by Razorpay.</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="checkout-layout">
      <div class="checkout-card">
        <h2>Step 1: Class Scheduling Information</h2>
        <p class="checkout-note">Share your country and city so we can align class schedules and coordinator support.</p>
        <form id="checkout-country-form" class="profile-setup-form" action="#" method="post">
          <div class="form-group">
            <label for="checkout-city">Your City</label>
            <input id="checkout-city" name="city" type="text" placeholder="Enter your city" required />
          </div>
          <div class="form-group">
            <label for="checkout-country">Your Country</label>
            <input id="checkout-country" name="country" type="text" placeholder="Enter your country" required />
          </div>
          <div class="form-group">
            <label for="checkout-postal-code">Postal Code</label>
            <input id="checkout-postal-code" name="postalCode" type="text" placeholder="Enter postal code" required />
          </div>
          <div class="form-group">
            <label for="checkout-coupon-code">Coupon Code (Optional)</label>
            <input id="checkout-coupon-code" name="couponCode" type="text" placeholder="Enter coupon code" />
          </div>
          <button type="button" class="btn btn-ghost" id="checkout-detect-location-btn">Detect My Location</button>
          <button type="submit" class="btn btn-primary">Continue to Price Summary</button>
        </form>

        <div id="checkout-payment-panel" hidden>
          <h2>Step 2: Razorpay Payment</h2>
          <p class="checkout-note">Click Pay Now to open Razorpay and complete your enrollment.</p>
          <button type="button" id="checkout-pay-btn" class="btn btn-primary" data-course-id="<%= course.id %>" data-course-title="<%= course.title %>">Pay Now</button>
        </div>

        <div id="checkout-feedback" class="auth-feedback" role="status" aria-live="polite"></div>
      </div>

      <aside class="checkout-summary sidebar-card">
        <h3>Order Summary</h3>
        <ul class="sidebar-info">
          <li>
            <span class="sidebar-label">Course</span>
            <span class="sidebar-value"><%= course.title %></span>
          </li>
          <li>
            <span class="sidebar-label">Category</span>
            <span class="sidebar-value"><%= course.category || 'General' %></span>
          </li>
          <li>
            <span class="sidebar-label">Mode</span>
            <span class="sidebar-value">Live + Guided</span>
          </li>
          <li>
            <span class="sidebar-label">Payment</span>
            <span class="sidebar-value">Razorpay</span>
          </li>
          <li>
            <span class="sidebar-label">Currency</span>
            <span class="sidebar-value" id="checkout-currency">INR</span>
          </li>
          <li>
            <span class="sidebar-label">Base Fee</span>
            <span class="sidebar-value" id="checkout-base-fee"><%= checkoutPricing.selectedFeeDisplay %></span>
          </li>
          <li>
            <span class="sidebar-label">GST</span>
            <span class="sidebar-value" id="checkout-gst-fee">INR 0.00</span>
          </li>
          <li>
            <span class="sidebar-label">Total Payable</span>
            <span class="sidebar-value" id="checkout-current-fee"><%= checkoutPricing.selectedFeeDisplay %></span>
          </li>
        </ul>
        <a href="/courses/<%= course.id %>" class="btn btn-ghost btn-block">Back to Course</a>
      </aside>
    </div>
  </div>
</section>

<script type="module" src="/js/checkout-page.js"></script>
<%- include('partials/footer') %>

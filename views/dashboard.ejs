<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section class="dashboard-shell section" data-dashboard-root>
  <div class="container">
    <div class="dashboard-header" data-animate="fade-left">
      <div class="dashboard-intro">
        <div class="section-tag">Dashboard</div>
        <h1 class="dashboard-title">Welcome, <span id="dashboard-user-name">Learner</span></h1>
        <p class="dashboard-sub">Complete and manage your learner profile.</p>
      </div>
      <div class="dashboard-header-actions">
        <a href="/courses" class="btn btn-ghost">Browse Courses</a>
        <button type="button" class="btn btn-primary" id="dashboard-signout">Sign Out</button>
      </div>
    </div>

    <div class="dashboard-gate" id="dashboard-gate">
      <div class="dashboard-gate-card">
        <div class="dashboard-gate-head">
          <div>
            <h2>Profile Studio</h2>
            <p id="dashboard-gate-copy">Complete your profile to unlock your full dashboard experience.</p>
          </div>
          <span class="dashboard-required" id="dashboard-required-pill">Required</span>
        </div>
        <form id="profile-setup-form" class="profile-setup-form" action="#" method="post">
          <div class="form-row">
            <div class="form-group">
              <label for="profile-name">Full Name</label>
              <input id="profile-name" name="name" type="text" required />
            </div>
            <div class="form-group">
              <label for="profile-age">Age</label>
              <input id="profile-age" name="age" type="number" min="10" max="100" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="profile-nationality">Nationality</label>
              <input id="profile-nationality" name="nationality" type="text" required />
            </div>
            <div class="form-group">
              <label for="profile-phone">Phone Number</label>
              <input id="profile-phone" name="phoneNumber" type="tel" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="profile-gender">Gender</label>
              <input id="profile-gender" name="gender" type="text" placeholder="Optional" />
            </div>
            <div class="form-group">
              <label for="profile-city">City</label>
              <input id="profile-city" name="city" type="text" required />
            </div>
          </div>
          <div class="form-group">
            <label for="profile-education">Highest Education</label>
            <input id="profile-education" name="education" type="text" required />
          </div>
          <button type="submit" class="btn btn-primary btn-block" id="profile-save-btn">Save Profile</button>
        </form>
        <div id="dashboard-gate-feedback" class="auth-feedback" role="status" aria-live="polite"></div>
      </div>
    </div>

    <div id="dashboard-content" hidden>
      <div class="dashboard-tabs" role="tablist" aria-label="Dashboard tabs">
        <button type="button" class="dashboard-tab-btn active" data-dashboard-tab-btn="overview" aria-selected="true">Overview</button>
        <button type="button" class="dashboard-tab-btn" data-dashboard-tab-btn="courses" aria-selected="false">Courses</button>
        <button type="button" class="dashboard-tab-btn" data-dashboard-tab-btn="settings" aria-selected="false">Settings</button>
      </div>

      <section class="dashboard-panel active" id="dashboard-tab-overview" data-dashboard-tab-panel="overview">
        <div class="dashboard-gate-card">
          <h2>Dashboard Ready</h2>
          <p>Your profile is complete. Use the Settings tab to review and update your details anytime.</p>
          <a href="/courses" class="btn btn-primary">Browse Courses</a>
        </div>
      </section>

      <section class="dashboard-panel" id="dashboard-tab-courses" data-dashboard-tab-panel="courses">
        <div class="dashboard-courses">
          <div class="dashboard-courses-head">
            <h2>Your Purchased Courses</h2>
            <a class="dashboard-link" href="/courses">Browse More</a>
          </div>
          <div id="dashboard-purchased-courses" class="dashboard-course-grid"></div>
          <p id="dashboard-purchased-empty" class="dashboard-course-cat" hidden>
            No purchased courses yet. Buy a course to see it here.
          </p>
        </div>
      </section>

      <section class="dashboard-panel" id="dashboard-tab-settings" data-dashboard-tab-panel="settings">
        <div class="dashboard-gate-card">
          <div class="dashboard-gate-head">
            <div>
              <h2>Profile Settings</h2>
              <p>Update your profile information below.</p>
            </div>
          </div>
          <form id="profile-settings-form" class="profile-setup-form" action="#" method="post">
            <div class="form-row">
              <div class="form-group">
                <label for="settings-profile-name">Full Name</label>
                <input id="settings-profile-name" name="name" type="text" required />
              </div>
              <div class="form-group">
                <label for="settings-profile-age">Age</label>
                <input id="settings-profile-age" name="age" type="number" min="10" max="100" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="settings-profile-nationality">Nationality</label>
                <input id="settings-profile-nationality" name="nationality" type="text" required />
              </div>
              <div class="form-group">
                <label for="settings-profile-phone">Phone Number</label>
                <input id="settings-profile-phone" name="phoneNumber" type="tel" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="settings-profile-gender">Gender</label>
                <input id="settings-profile-gender" name="gender" type="text" placeholder="Optional" />
              </div>
              <div class="form-group">
                <label for="settings-profile-city">City</label>
                <input id="settings-profile-city" name="city" type="text" required />
              </div>
            </div>
            <div class="form-group">
              <label for="settings-profile-education">Highest Education</label>
              <input id="settings-profile-education" name="education" type="text" required />
            </div>
            <button type="submit" class="btn btn-primary btn-block" id="settings-save-btn">Save Changes</button>
          </form>
          <div id="dashboard-settings-feedback" class="auth-feedback" role="status" aria-live="polite"></div>
        </div>
      </section>
    </div>

  </div>
</section>

<script type="module" src="/js/dashboard.js"></script>
<%- include('partials/footer') %>

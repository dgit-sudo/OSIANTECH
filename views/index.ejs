<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="container">
    <div class="hero-content" data-animate="fade-up">
      <p class="hero-label">Professional Online Education</p>
      <h1 class="hero-title">Expert-led learning.<br><span class="hero-accent">Real outcomes.</span></h1>
      <p class="hero-desc">1-on-1 mentored courses in technology, design, and business. Every session is live, personal, and built around your goals.</p>
      <div class="hero-actions">
        <a href="/courses" class="btn btn-primary btn-lg">Browse Courses</a>
        <a href="/auth?mode=signup" class="btn btn-ghost btn-lg" data-auth-guest>Create Account</a>
        <a href="/dashboard" class="btn btn-ghost btn-lg" data-auth-user hidden>Go to Dashboard</a>
      </div>
    </div>
    <div class="hero-aside" data-animate="fade-up" style="transition-delay:.1s">
      <div class="hero-feature-list">
        <div class="hero-feature-item">
          <div class="hero-feature-dot"></div>
          <div>
            <p class="hero-feature-title">1-on-1 live sessions</p>
            <p class="hero-feature-desc">Direct time with your instructor, not a pre-recorded video</p>
          </div>
        </div>
        <div class="hero-feature-item">
          <div class="hero-feature-dot"></div>
          <div>
            <p class="hero-feature-title">Industry-certified instructors</p>
            <p class="hero-feature-desc">Taught by professionals with real-world experience</p>
          </div>
        </div>
        <div class="hero-feature-item">
          <div class="hero-feature-dot"></div>
          <div>
            <p class="hero-feature-title">Structured curriculum</p>
            <p class="hero-feature-desc">Clear progression from fundamentals to advanced topics</p>
          </div>
        </div>
        <div class="hero-feature-item">
          <div class="hero-feature-dot"></div>
          <div>
            <p class="hero-feature-title">Recognised certification</p>
            <p class="hero-feature-desc">Credentials valued by employers across industries</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== DIVIDER STATS ===== -->
<div class="stats-strip">
  <div class="container">
    <div class="stats-strip-inner">
      <div class="stats-strip-item">
        <span class="stats-strip-val">1-on-1</span>
        <span class="stats-strip-label">Personal mentorship model</span>
      </div>
      <div class="stats-strip-divider"></div>
      <div class="stats-strip-item">
        <span class="stats-strip-val">Live</span>
        <span class="stats-strip-label">Interactive online sessions</span>
      </div>
      <div class="stats-strip-divider"></div>
      <div class="stats-strip-item">
        <span class="stats-strip-val">Expert</span>
        <span class="stats-strip-label">Certified industry instructors</span>
      </div>
      <div class="stats-strip-divider"></div>
      <div class="stats-strip-item">
        <span class="stats-strip-val">Flexible</span>
        <span class="stats-strip-label">Sessions on your schedule</span>
      </div>
    </div>
  </div>
</div>

<!-- ===== COURSES ===== -->
<section class="section" id="courses">
  <div class="container">
    <div class="section-header-row" data-animate="fade-up">
      <div>
        <p class="section-label">Course Catalog</p>
        <h2 class="section-title">Available programmes</h2>
      </div>
      <a href="/courses" class="btn btn-ghost">View all courses →</a>
    </div>
    <% if (featuredCourses.length) { %>
    <div class="catalog-carousel" data-catalog-carousel>
      <button type="button" class="catalog-nav catalog-nav-prev" data-carousel-prev aria-label="Previous">‹</button>
      <div class="catalog-viewport">
        <div class="catalog-track" data-carousel-track>
          <% featuredCourses.forEach(function(course) { %>
          <div class="catalog-slide">
            <a href="/courses/<%= course.id %>" class="course-card-link" data-animate="fade-up">
              <article class="course-card">
                <div class="course-img course-img-<%= (course.id % 9) + 1 %> <%= course.image ? 'has-course-image' : '' %>"<% if (course.image) { %> style="--course-image: url('<%= course.image %>');"<% } %>>
                  <div class="course-category-tag"><%= course.category || 'General' %></div>
                </div>
                <div class="course-body">
                  <h3 class="course-title"><%= course.title %></h3>
                  <p class="course-description"><%= course.description %></p>
                  <div class="course-footer">
                    <span class="course-meta-pill">Professional Programme</span>
                    <span class="course-arrow">→</span>
                  </div>
                </div>
              </article>
            </a>
          </div>
          <% }); %>
        </div>
      </div>
      <button type="button" class="catalog-nav catalog-nav-next" data-carousel-next aria-label="Next">›</button>
    </div>
    <% } else { %>
    <div class="course-empty" data-animate="fade-up">
      <h3>No courses available yet</h3>
      <p>The course catalog is currently being prepared.</p>
      <a href="/courses" class="btn btn-primary">Open Courses Page</a>
    </div>
    <% } %>
  </div>
</section>

<!-- ===== WHY ===== -->
<section class="section why-section" id="why">
  <div class="container">
    <div class="why-layout">
      <div class="why-left" data-animate="fade-up">
        <p class="section-label">Why Osian Academy</p>
        <h2 class="section-title">Education built around you</h2>
        <p class="why-body">Every learner is different. That is why our courses are delivered one-on-one with a dedicated instructor — no crowded classrooms, no generic content. Just focused time on your specific goals.</p>
        <a href="/courses" class="btn btn-primary">Explore Programmes</a>
      </div>
      <div class="why-right" data-animate="fade-up" style="transition-delay:.1s">
        <div class="why-grid">
          <div class="why-item">
            <p class="why-item-title">Personal attention</p>
            <p class="why-item-desc">Each session is scheduled directly with your instructor, ensuring the curriculum adapts to your pace and learning style.</p>
          </div>
          <div class="why-item">
            <p class="why-item-title">Real-world curriculum</p>
            <p class="why-item-desc">Course content is built in collaboration with industry professionals and updated to reflect current practices.</p>
          </div>
          <div class="why-item">
            <p class="why-item-title">Career-focused outcomes</p>
            <p class="why-item-desc">Every programme is designed with a specific career outcome in mind — from job readiness to skill advancement.</p>
          </div>
          <div class="why-item">
            <p class="why-item-title">Ongoing support</p>
            <p class="why-item-desc">Access to your instructor between sessions for questions, guidance, and accountability through your journey.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== CATEGORIES ===== -->
<section class="section section-alt" id="categories">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <p class="section-label">Browse by Subject</p>
      <h2 class="section-title">Every field. Every level.</h2>
    </div>
    <div class="categories-grid" data-animate="fade-up" style="transition-delay:.05s">
      <a href="/courses?category=Technology" class="cat-card">
        <div class="cat-icon cat-icon-blue">⚡</div>
        <div><h3>Technology</h3><p>Web, Mobile, Cloud &amp; More</p></div>
      </a>
      <a href="/courses?category=Data" class="cat-card">
        <div class="cat-icon cat-icon-teal">📊</div>
        <div><h3>Data Science</h3><p>ML, AI &amp; Analytics</p></div>
      </a>
      <a href="/courses?category=Design" class="cat-card">
        <div class="cat-icon cat-icon-purple">🎨</div>
        <div><h3>Design</h3><p>UI/UX, Branding &amp; Motion</p></div>
      </a>
      <a href="/courses?category=Security" class="cat-card">
        <div class="cat-icon cat-icon-red">🔐</div>
        <div><h3>Cybersecurity</h3><p>Ethical Hacking &amp; Defence</p></div>
      </a>
      <a href="/courses?category=Cloud" class="cat-card">
        <div class="cat-icon cat-icon-sky">☁️</div>
        <div><h3>Cloud &amp; DevOps</h3><p>AWS, Azure &amp; Kubernetes</p></div>
      </a>
      <a href="/courses?category=Business" class="cat-card">
        <div class="cat-icon cat-icon-amber">📈</div>
        <div><h3>Business</h3><p>Strategy, Marketing &amp; Finance</p></div>
      </a>
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="cta-section" id="enroll">
  <div class="container">
    <div class="cta-content" data-animate="fade-up">
      <p class="section-label cta-label">Get started</p>
      <h2 class="cta-title">Ready to begin?</h2>
      <p class="cta-sub">Admissions are open. Create your account to access the platform and receive updates when new courses are published.</p>
      <div class="cta-actions">
        <a href="/auth?mode=signup" class="btn btn-white btn-lg" data-auth-guest>Create Account</a>
        <a href="/auth?mode=signin" class="btn btn-outline-white btn-lg" data-auth-guest>Sign In</a>
        <a href="/dashboard" class="btn btn-white btn-lg" data-auth-user hidden>Go to Dashboard</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

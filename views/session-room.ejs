<%- include('partials/head') %>

<section class="section session-shell" data-session-page data-meeting-id="<%= meetingId %>" data-course-slug="<%= courseSlug %>" data-course-title="<%= courseTitle %>" data-instructor-name="<%= instructorName %>" data-class-no="<%= classNo %>">
  <div class="container session-room">
    <header class="session-topbar">
      <div class="session-topbar-copy">
        <a href="/" class="session-brand" aria-label="Osian Academy home">
          <img src="/images/osian-logo-transparent.svg" alt="Osian Academy" class="session-brand-logo" />
          <span class="session-brand-text">Osian Academy</span>
        </a>
        <div class="session-quick-meta">
          <span class="session-quick-meta-item">Course: <strong id="session-course-name"><%= courseTitle %></strong></span>
          <span class="session-quick-meta-item">Instructor: <strong id="session-instructor-name"><%= instructorName %></strong></span>
          <span class="session-quick-meta-item">Class: <strong id="session-class-no"><%= classNo %></strong></span>
        </div>
      </div>
      <div class="session-topbar-pills">
        <div id="session-role" class="dashboard-chip">Role</div>
        <div id="session-connection-state" class="session-state-pill">Connecting</div>
        <div id="session-participant-count" class="session-state-pill session-state-pill-soft">1 participant</div>
      </div>
    </header>

    <div class="session-body">
      <main class="session-stage-shell">
        <section class="session-stage-card">
          <div class="session-stage-head">
            <div>
              <p class="session-stage-kicker">Meeting stage</p>
              <h2 class="session-stage-title">Classroom Call</h2>
            </div>
            <div class="session-stage-meta">
              <span class="session-stage-chip">HD</span>
              <span class="session-stage-chip">Encrypted</span>
            </div>
          </div>

          <section class="session-video-grid" id="session-video-grid">
            <article class="session-video-card session-video-card--self">
              <header>
                <span>You</span>
                <span class="session-video-tag">Local</span>
              </header>
              <video id="session-local-video" autoplay playsinline muted></video>
            </article>
          </section>

          <div class="session-control-dock" id="session-control-dock">
            <button type="button" class="session-control-btn session-control-btn--icon session-control-btn--primary" id="session-toggle-mic" title="Mute microphone" aria-label="Mute microphone">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 15a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3Zm5-3a1 1 0 1 1 2 0 7 7 0 1 1-14 0 1 1 0 1 1 2 0 5 5 0 0 0 10 0Zm-4 8a1 1 0 1 1-2 0v-2a1 1 0 1 1 2 0v2Z"/></svg>
              <span data-btn-label>Mute</span>
            </button>
            <button type="button" class="session-control-btn session-control-btn--icon session-control-btn--primary" id="session-toggle-cam" title="Turn off camera" aria-label="Turn off camera">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1.7l3.6-2.4A1 1 0 0 1 20 6v12a1 1 0 0 1-1.4.9L15 16.3V18a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6Zm12 4.7v2.6l3 2V8.7l-3 2Z"/></svg>
              <span data-btn-label>Camera</span>
            </button>
            <button type="button" class="session-control-btn session-control-btn--icon" id="session-share-screen" title="Share screen" aria-label="Share screen">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-6v2h2a1 1 0 1 1 0 2H8a1 1 0 1 1 0-2h2v-2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm0 2v9h16V6H4Z"/></svg>
              <span data-btn-label>Share</span>
            </button>
            <button type="button" class="session-control-btn session-control-btn--icon" id="session-toggle-chat" title="Toggle chat panel" aria-label="Toggle chat panel">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H8l-4 3v-3H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm2 4a1 1 0 0 0 0 2h12a1 1 0 1 0 0-2H6Zm0 4a1 1 0 0 0 0 2h8a1 1 0 1 0 0-2H6Z"/></svg>
              <span data-btn-label>Chat</span>
            </button>
            <button type="button" class="session-control-btn session-control-btn--icon" id="session-toggle-whiteboard" title="Toggle whiteboard panel" aria-label="Toggle whiteboard panel">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2h2a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2v1a1 1 0 1 1-2 0v-1H5a2 2 0 0 1-2-2V5Zm2 0v12h10V5H5Zm12 4v8h2V9h-2Z"/></svg>
              <span data-btn-label>Board</span>
            </button>
            <div class="session-more-wrap" id="session-more-wrap">
              <button type="button" class="session-control-btn session-control-btn--icon" id="session-more-btn" title="More actions" aria-label="More actions">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 10a2 2 0 1 1 0 4 2 2 0 0 1 0-4Zm6 0a2 2 0 1 1 0 4 2 2 0 0 1 0-4Zm6 0a2 2 0 1 1 0 4 2 2 0 0 1 0-4Z"/></svg>
                <span data-btn-label>More</span>
              </button>
              <div class="session-more-menu" id="session-more-menu" hidden>
                <button type="button" class="session-more-item" id="session-support">
                  <span>Raise Technical Support</span>
                </button>
                <button type="button" class="session-more-item session-more-item--danger" id="session-end-class" hidden>
                  <span>End Class</span>
                </button>
              </div>
            </div>
          </div>

          <div id="session-feedback" class="auth-feedback" role="status" aria-live="polite"></div>
        </section>
      </main>

      <aside class="session-sidepanel" id="session-sidepanel" hidden>
        <article class="session-chat-card" id="session-chat-panel" hidden>
          <div class="session-chat-head">
            <span class="session-chat-status-dot" aria-hidden="true"></span>
            <h2 class="session-chat-title">Meeting Chat</h2>
            <span class="session-chat-badge">Live</span>
          </div>
          <div id="session-chat-list" class="session-chat-list" role="log" aria-live="polite" aria-label="Chat messages">
            <div class="session-chat-empty" id="session-chat-empty">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <p>No messages yet. Say hi!</p>
            </div>
          </div>
          <form id="session-chat-form" class="session-chat-form" action="#" method="post" autocomplete="off">
            <input id="session-chat-input" type="text" placeholder="Message everyone in the room" maxlength="500" required autocomplete="off" />
            <button type="submit" class="session-chat-send" aria-label="Send message">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
            </button>
          </form>
        </article>

        <article class="session-whiteboard-card" id="session-whiteboard-wrap" hidden>
          <div class="session-whiteboard-head">
            <div>
              <p class="session-stage-kicker">Collaboration</p>
              <h2>Whiteboard</h2>
            </div>
            <button type="button" class="btn btn-ghost" id="session-whiteboard-clear">Clear Board</button>
          </div>
          <canvas id="session-whiteboard" width="960" height="420"></canvas>
        </article>
      </aside>
    </div>
  </div>
</section>

<script src="/socket.io/socket.io.js?v=<%= assetVersion %>"></script>
<script type="module" src="/js/session-room.js?v=<%= assetVersion %>"></script>
</body>
</html>
